{
  "schemaVersion": 1,
  "id": "better_screenshots",
  "version": "${version}",
  "name": "Better ScreenShots",
  "description": "Enhance your screenshots with previews, sounds, and an in-game gallery!",
  "authors": ["GDLev"],
  "contact": {},
  "license": "All-Rights-Reserved",
  "icon": "assets/better_screenshots/icon.png",
  "environment": "client",
  "entrypoints": {
    "fabric-datagen": [
      "dev.gdlev.better_screenshots.client.Better_screenshotsDataGenerator"
    ],
    "client": [
      "dev.gdlev.better_screenshots.client.Better_screenshotsClient"
    ],
    "main": [
      "dev.gdlev.better_screenshots.Better_screenshots"
    ]
  },
  "mixins": [
    "better_screenshots.mixins.json",
    {
      "config": "better_screenshots.client.mixins.json",
      "environment": "client"
    }
  ],
  "depends": {
    "fabricloader": ">=${loader_version}",
    "fabric-api": "*",
    "fabric-command-api-v2": "*",
    "minecraft": "${minecraft_version}"
  }
}
